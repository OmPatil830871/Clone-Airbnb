<%- layout('/layouts/boilerplate.ejs') %>
    <div class="row">
        <h1 class="text-center">Login Form</h1>
        <div class="col-6 offset-3">
            <form action="/login" method="POST" novalidate class="needs-validation" id="signupForm">
                <div class="mb-3">
                    <label class="form-label" for="username">Username</label>
                    <input required class="form-control" type="text" id="username" name="username">
                    <div class="invalid-feedback">Please provide a valid username.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="password">Password</label>
                    <input required class="form-control" type="password" id="password" name="password" minlength="6">
                    <div class="invalid-feedback">Password must be at least 6 characters.</div>
                </div>
                <button class="btn btn-success" type="submit">Login</button>
            </form>
        </div>
    </div>