<% layout("/layouts/boilerplate") %>


    <style>
        #filters {
            display: flex;
            align-items: center;
            overflow-x: auto;
            white-space: nowrap;
        }
        
        .filters {
            text-decoration: none;
            text-align: center;
            margin-top: 1rem;
            margin-right: 2rem;
            opacity: 0.7;
        }
        
        .filters:hover {
            color: black;
            opacity: 1;
        }
        
        .filters div a {
            color: black;
            text-decoration: none;
            opacity: 0.7;
        }
        
        .tax-info {
            display: none;
        }
        
        .tax-toggle {
            border: 1px solid black;
            height: 2.8rem;
            border-radius: 1rem;
            padding: 0.5rem 1rem;
            margin-left: auto;
            display: flex;
            align-items: center;
            white-space: nowrap;
        }
    </style>

    <nav class="navbar navbar-expand-lg bg-white mb-3">
        <div class="container-fluid">

            <!-- Toggle Button -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#filtersNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

            <!-- Category Filters (Collapsible) -->
            <div class="collapse navbar-collapse" id="filtersNavbar">
                <div id="filters" class="navbar-nav">
                    <div class="filters">
                        <div><a href="/listings/category/mountain"><i class="fa-solid fa-mountain"></i></a>
                            <p>Mountain</p>
                        </div>
                    </div>
                    <div class="filters nav-item">
                        <div><a href="/listings/category/beach"><i class="fa-solid fa-umbrella-beach"></i></a>
                            <p>Beach</p>
                        </div>
                    </div>
                    <div class="filters nav-item">
                        <div>
                            <a href="/listings/category/farm"><i class="fa-solid fa-cow"></i></a>
                            <p>Farm</p>
                        </div>
                    </div>
                    <div class="filters nav-item">
                        <div> <a href="/listings/category/castle"><i class="fa-brands fa-fort-awesome"></i></a>
                            <p>Castle</p>
                        </div>
                    </div>
                    <div class="filters nav-item">
                        <div><a href="/listings/category/pool"><i class="fa-solid fa-person-swimming"></i></a>
                            <p>Pool</p>
                        </div>
                    </div>
                    <div class="filters nav-item">
                        <div>
                            <a href="/listings/category/cities"><i class="fa-solid fa-city"></i></a>
                        </div>
                        <p>Cities</p>
                    </div>
                    <div class="filters nav-item">
                        <div>
                            <a href="/listings/category/campain"><i class="fa-solid fa-campground"></i></a>
                        </div>
                        <p>Camping</p>
                    </div>
                    <div class="filters nav-item">
                        <div>
                            <a href="/listings/category/forest">
                                <i class="fa-solid fa-tree"></i>
                            </a>
                            <p>Forest</p>
                        </div>
                    </div>
                    <div class="filters nav-item">
                        <div>
                            <a href="/listings/category/desert">
                                <i class="fa-solid fa-sun"></i>
                            </a>
                            <p>Desert</p>
                        </div>
                    </div>
                    <div class="filters nav-item">
                        <div>
                            <a href="/listings/category/island">
                                <i class="fa-regular fa-image"></i>
                            </a>
                            <p>Island</p>
                        </div>
                    </div>
                </div>
            </div>


            <div class="tax-toggle">
                <div class="form-check-reverse form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                </div>
            </div>
        </div>
    </nav>
    <!-- <form method="get" action="/listings/new">
            <button>Create New Listing</button>
        </form> -->
    <br>
    <div class="row  row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <% for (listing of allListings){ %>
            <a href="/listings/<%=listing._id %>" class="listing-link">
                <div class="card col listing-card" style="width: 20rem;">
                    <img src="<%=listing.image.url%>" class="card-img-top" alt="/listing.img" style="height:20rem;">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b><br> &#8377;
                            <%=listing.price.toLocaleString("en-IN") %>/night
                                <i class="tax-info"> &nbsp;&nbsp;+18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
            <%} %>
    </div>

    <script>
        let taxswich = document.getElementById("switchCheckDefault");
        taxswich.addEventListener("click", () => {
            let taxinfo = document.getElementsByClassName("tax-info");
            for (info of taxinfo) {
                if (info.style.display != "inline") {
                    info.style.display = "inline";
                } else {
                    info.style.display = "none"
                }
            }
        })
    </script>