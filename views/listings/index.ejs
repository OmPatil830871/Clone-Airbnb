<% layout("/layouts/boilerplate") %>

    <style>
        /* FILTER NAVBAR */
        
        #filtersNavbar {
            background-color: white;
            padding: 1rem;
            width: 100%;
        }
        /* FILTERS */
        
        #filters {
            display: flex;
            align-items: center;
            overflow-x: auto;
            white-space: nowrap;
        }
        
        .filters {
            margin: 1rem;
            opacity: 0.7;
            flex-shrink: 0;
            text-decoration: none;
            color: black;
            display: block;
            text-align: center;
        }
        
        .filters:hover {
            opacity: 1;
        }
        
        .filters div {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .filters i {
            font-size: 1.3rem;
        }
        
        .filters p {
            margin: 0;
            font-size: 0.8rem;
        }
        /* TAX */
        
        .tax-toggle {
            border: 1px solid black;
            height: 2.8rem;
            border-radius: 1rem;
            padding: 0.5rem 1rem;
            margin-left: auto;
            display: flex;
            align-items: center;
            white-space: nowrap;
        }
        
        .tax-info {
            display: none;
        }
        /* MOBILE */
        
        @media (max-width: 768px) {
            #filters {
                flex-direction: column;
                align-items: flex-start;
                width: 100%;
            }
            .filters {
                width: 100%;
                border-bottom: 1px solid #ddd;
                padding: 0.8rem 0;
            }
            .filters div {
                flex-direction: row;
                gap: 1rem;
            }
            .filters p {
                font-size: 1rem;
            }
            .tax-toggle {
                width: 100%;
                margin-top: 1rem;
                justify-content: space-between;
            }
        }
        /* LISTINGS */
        
        .listing-link {
            text-decoration: none;
            color: black;
        }
        
        .listing-card {
            margin-bottom: 2rem;
            border: none;
            transition: transform 0.2s;
        }
        
        .listing-card:hover {
            transform: scale(1.02);
        }
        
        .card-img-top {
            border-radius: 1rem;
            object-fit: cover;
        }
        
        .row {
            margin-top: 1rem;
        }
    </style>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg bg-white mb-3 shadow-sm">
        <div class="container-fluid">

            <!-- HAMBURGER -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#filtersNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

            <!-- MENU -->
            <div class="collapse navbar-collapse" id="filtersNavbar">

                <!-- FILTERS -->
                <div id="filters" class="navbar-nav">

                    <% const categories = [
                {name:"Mountain", icon:"fa-mountain", url:"mountain"},
                {name:"Beach", icon:"fa-umbrella-beach", url:"beach"},
                {name:"Farm", icon:"fa-cow", url:"farm"},
                {name:"Castle", icon:"fa-fort-awesome", url:"castle"},
                {name:"Pool", icon:"fa-person-swimming", url:"pool"},
                {name:"Cities", icon:"fa-city", url:"cities"},
                {name:"Camping", icon:"fa-campground", url:"campain"},
                {name:"Forest", icon:"fa-tree", url:"forest"},
                {name:"Desert", icon:"fa-sun", url:"desert"},
                {name:"Island", icon:"fa-image", url:"island"}
                ]; %>

                        <% for(let cat of categories){ %>
                            <a href="/listings/category/<%=cat.url%>" class="filters nav-item">
                                <div>
                                    <i class="fa-solid <%=cat.icon%>"></i>
                                    <p>
                                        <%=cat.name%>
                                    </p>
                                </div>
                            </a>
                            <% } %>

                </div>

                <!-- TAX -->
                <div class="tax-toggle">
                    <div class="form-check-reverse form-switch">
                        <input class="form-check-input" type="checkbox" id="switchCheckDefault">
                        <label class="form-check-label">Display total after taxes</label>
                    </div>
                </div>

            </div>
        </div>
    </nav>

    <!-- LISTINGS -->
    <div class="container">
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">

            <% for (listing of allListings){ %>
                <div class="col">
                    <a href="/listings/<%=listing._id %>" class="listing-link">
                        <div class="card listing-card">
                            <img src="<%=listing.image.url%>" class="card-img-top" style="height:20rem;">
                            <div class="card-body">
                                <p class="card-text">
                                    <b><%= listing.title %></b><br> ₹
                                    <%=listing.price.toLocaleString("en-IN") %>/night
                                        <i class="tax-info"> +18% GST</i>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
                <% } %>

        </div>
    </div>

    <script>
        // TAX TOGGLE
        let taxswitch = document.getElementById("switchCheckDefault");

        taxswitch.addEventListener("click", () => {
            let taxinfo = document.getElementsByClassName("tax-info");
            for (let info of taxinfo) {
                info.style.display = (info.style.display !== "inline") ? "inline" : "none";
            }
        });

        document.querySelectorAll(".filters").forEach(item => {
            item.addEventListener("click", () => {
                let navbarCollapse = document.getElementById("filtersNavbar");
                let bsCollapse = new bootstrap.Collapse(navbarCollapse, {
                    toggle: false
                });
                bsCollapse.hide();
            });
        });
    </script>