<% layout("/layouts/boilerplate") %>

    <div class="row mt-3">
        <div class="col-8 offset-2">

            <h2>Edit Your Listing</h2>

            <form method="post" action="/listings/<%= listing._id %>?_method=PATCH" novalidate class="needs-validation" enctype="multipart/form-data">

                <div class="mb-2">
                    <label class="form-label">Title</label>
                    <input type="text" value="<%= listing.title %>" name="listing[title]" class="form-control" required>
                </div>

                <div class="mb-2">
                    <label class="form-label">Description</label>
                    <textarea name="listing[description]" class="form-control" required><%= listing.description %></textarea>
                </div>

                <div class="mb-2">
                    <img src="<%= originalurl %>" style="height: 15vh; width:10rem;">
                </div>

                <div class="mb-2">
                    <label class="form-label">Upload New Image</label>
                    <input type="file" name="image" class="form-control">
                </div>

                <div class="row">
                    <div class="mb-2 col-md-3">
                        <label class="form-label">Price</label>
                        <input class="form-control" value="<%= listing.price %>" name="listing[price]" required>
                    </div>
                    <div class="mb-2 col-3">
                        <label class="form-label">Category</label>
                        <select name="listing[category]" class="form-select" required>
                                <option value="">Select Category</option>
                                <option value="mountain"> Mountain</option>
                                <option value="beach">Beach</option>
                                <option value="farm">Farm</option>
                                <option value="cities">cities</option>
                                <option value="campain">campaing</option>
                                <option value="castle">castle</option>
                                <option value="pool">pool</option>
                                <option value="forest">forest</option>
                                <option value="desert">desert</option>
                                <option value="island">island</option>
                            </select>
                    </div>

                    <div class="mb-2 col-md-3">
                        <label class="form-label">Country</label>
                        <input type="text" class="form-control" value="<%= listing.country %>" name="listing[country]" required>
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label">Location</label>
                    <input type="text" class="form-control" value="<%= listing.location %>" name="listing[location]" required>
                </div>

                <button class="btn btn-dark mt-3 mb-2">Edit</button>
            </form>
        </div>
    </div>